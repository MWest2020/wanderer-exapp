<?xml version="1.0"?>
<!--
  ExApp App-Store packaging manifest. The <external-app><docker-install>
  structure below matches the official nextcloud/app-skeleton-python
  reference (confirmed 2026-06-15) and is well-formed.

  Still to confirm at App-Store publish time: the <scopes> values your
  features actually need, and the NC min/max-version window. The live
  runtime contract (AppAPI auth + lifecycle) was validated separately
  via `occ app_api:app:register --json-info` against NC 30.0.17 — see
  the README; the store-publish path additionally exercises this file.
  Ref: https://docs.nextcloud.com/server/stable/developer_manual/exapp_development/tech_details/Deployment.html
-->
<info>
    <id>wanderer</id>
    <name>Wanderer</name>
    <summary>Sovereignty observation for your Nextcloud</summary>
    <description><![CDATA[
Wanderer observes the externally visible digital footprint of an
organisation (DNS, MX, TLS, HTTP, IP/ASN) and scores it for Dutch /
EU digital sovereignty. This ExApp packages Wanderer as a Nextcloud
External App: the AppAPI deploy daemon runs it as a container, no
separate binary for the admin to manage.

The Wanderer core is pure Go and lives upstream at
github.com/MWest2020/wanderer; this app only adds the AppAPI surface.
    ]]></description>
    <version>0.1.0</version>
    <licence>EUPL-1.2</licence>
    <author>Conduction B.V.</author>
    <namespace>Wanderer</namespace>
    <category>security</category>
    <category>monitoring</category>
    <bugs>https://github.com/MWest2020/wanderer-exapp/issues</bugs>
    <dependencies>
        <nextcloud min-version="30" max-version="31"/>
    </dependencies>
    <external-app>
        <docker-install>
            <registry>ghcr.io</registry>
            <image>mwest2020/wanderer-exapp</image>
            <image-tag>latest</image-tag>
        </docker-install>
        <!-- Wanderer's UI/API is self-contained; it needs no Nextcloud
             data scopes for the first wave. Add scopes here only when a
             feature reads Nextcloud user/file data. -->
        <scopes></scopes>
    </external-app>
</info>
